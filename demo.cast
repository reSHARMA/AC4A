[29.650045, "o", "\r\n"]
[30.559197, "o", "\u001b[1;34;40mCalling CalendarAPI check_available with start_time=2025-07-10 00:00:00, duration=7 days, 0:00:00\u001b[0m\r\n\u001b[1;36;40mChecking policy:\u001b[0m {'granular_data': 'Expedia:Destination', 'data_access': 'Read', 'position': 'Current'}\r\n"]
